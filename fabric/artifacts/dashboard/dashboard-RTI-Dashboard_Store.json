entEnqueuedUtcTime  >= _startTime\n| join kind=inner external_table('store') on StoreLocation\n| where StoreID  == _store \n| summarize Inventory=count() by StockAvailabilityStatus\n\n\n","id":"8bb8d7dc-cf29-47e9-a143-2881b9c7d7f3","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"dc9b22f6-5e41-48df-97c8-ef20e968feaa"},"text":"// This KQL query was generated by AI:\n// give me average of temp by enqueuedtimeutc from thermostat table\n//\nProductInventory\n| where  EventEnqueuedUtcTime  >= _startTime\n| join kind=inner external_table('store') on StoreLocation\n| where StoreID  == _store \n| summarize FootTraffic=round(sum(InventorySKU)/20,0)\n\n","id":"af151ef3-3333-4557-ad41-16629a709dce","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"dc9b22f6-5e41-48df-97c8-ef20e968feaa"},"text":"// This KQL query was generated by AI:\n// give me average of temp by enqueuedtimeutc from thermostat table\n//\nInventory\n| where EventEnqueuedUtcTime  >=  _startTime\n| join kind=inner external_table('store') on StoreLocation\n| where StoreID  == _store \n| summarize Inventory=round(sum(InventorySKU),0) by StoreLocation\n","id":"693abaa9-5c25-4218-87b5-e774b72ee25b","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"dc9b22f6-5e41-48df-97c8-ef20e968feaa"},"text":"ProductInventory\r\n| where  EventEnqueuedUtcTime  >= _startTime\r\n| join kind=inner external_table('store') on StoreLocation\r\n| where StoreID  == _store \r\n| extend Products_Sold = 100 - toint(InventorySKU)\r\n| summarize Total_Products_Sold = sum(Products_Sold) by ProductName\r\n| order by Total_Products_Sold desc\r\n| top 5 by Total_Products_Sold desc","id":"c8ded755-a555-4bf4-af4e-7a54ead3b451","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"dc9b22f6-5e41-48df-97c8-ef20e968feaa"},"text":"let AvgDailySales =\r\n    [' factsales(snowflake)']\r\n    | summarize TotalSold=sum(Quantity), FirstSale=min(SaleDate), LastSale=max(SaleDate) by ProductID\r\n    | extend Days = datetime_diff('day', LastSale, FirstSale) + 1\r\n    | extend AvgDailySales = iif(Days > 0, TotalSold * 1.0 / Days, TotalSold * 1.0)\r\n    | project ProductID, AvgDailySales;\r\nlet PredictedInventory =\r\n    Inventory\r\n    | where isnotempty(InventorySKU) and toint(InventorySKU) > 0\r\n    | join kind=leftouter (AvgDailySales) on ProductID\r\n    | join kind=inner (store) on StoreLocation\r\n    | where StoreID == _store\r\n    | extend PredictedDays = toreal(InventorySKU) / iif(isnull(AvgDailySales) or AvgDailySales == 0, 1.0, AvgDailySales)\r\n    | project ProductID, ProductName, StoreLocation, InventorySKU, AvgDailySales, PredictedDays;\r\nlet MinPredictedDays =\r\n    PredictedInventory\r\n    | summarize minPredictedDays=min(PredictedDays) by ProductName, StoreLocation;\r\nPredictedInventory\r\n| join kind=inner (MinPredictedDays) on ProductName, StoreLocation\r\n| where PredictedDays == minPredictedDays\r\n| project ProductID, ProductName, StoreLocation, InventorySKU, AvgDailySales, PredictedDays\r\n| extend PredictedTimeLeft =\r\n    case(\r\n        PredictedDays >= 1, strcat(tostring(toint(PredictedDays)), \" days\"),\r\n        PredictedDays * 24 >= 1, strcat(tostring(toint(PredictedDays * 24)), \" hours\"),\r\n        strcat(tostring(toint(PredictedDays * 24 * 60)), \" mins\")\r\n    )\r\n| project ProductID, ProductName, StoreLocation, PredictedTimeLeft, PredictedDaysRounded=round(PredictedDays,2)","id":"b065177e-ab02-494c-af23-a5217ce5198d","usedVariables":["_store"]},{"dataSource":{"kind":"inline","dataSourceId":"e0f6e180-16c0-4e01-b03c-19d9f51f48e1"},"text":"// Please enter your KQL query (Example):\n// <table name>\n// | where <datetime column> between (['_startTime'] .. ['_endTime']) // Time range filtering\n// | take 100\nexternal_table('store')\n| distinct StoreID\n| sort by StoreID asc ","id":"67388e82-fed1-4e20-b079-6e93ac4416ef","usedVariables":[]}]}