SKU = round(avg(InventorySKU),0) by ProductName\n|where  InventorySKU  < 10 ","id":"16ebd85c-ecea-430b-95c9-b0de989a0a5f","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"9a1d0b2b-f87b-46bb-850b-862c50de8a15"},"text":"\nlet _startTime = datetime(2025-04-15T11:21:41Z);\nunion \n(\n    ['factsales(snowflake)']\n    | join kind=inner (store) on StoreLocation\n    | where StoreID == _store \n    | where SaleDate >= _startTime\n    | summarize Qty=sum(toint(Quantity)), Status=\"Sales\" by ProductName\n),\n(\n    Return_sales\n    | join kind=inner (store) on StoreLocation\n    | where StoreID == _store \n    | where todatetime(ReturnDate) >= _startTime\n    | summarize Qty=count(), Status=\"Returns\" by ProductName\n)\n| where ProductName !in (\"Velvet Merlot\", \"Pale Meadow\")\n| order by Status desc\n| render columnchart","id":"0ed14255-a3d1-47de-b7e2-e6956027ea3d","usedVariables":["_store"]},{"dataSource":{"kind":"inline","dataSourceId":"9a1d0b2b-f87b-46bb-850b-862c50de8a15"},"text":"external_table('Return_sales')\n|join kind=inner external_table('store') on StoreLocation\n|where StoreID  == _store \n|where todatetime(ReturnDate) >= _startTime\n|summarize Returns = count() by ReturnReason\n","id":"ca483d57-63ac-4251-97ce-3d1282c56d50","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"9a1d0b2b-f87b-46bb-850b-862c50de8a15"},"text":"Return_sales\n| join kind=inner store on StoreLocation\n| where StoreID == _store\n| where todatetime(ReturnDate) >= _startTime\n| summarize Returns=count()","id":"2e77f444-254f-437f-a48e-a0fa24e26277","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"9a1d0b2b-f87b-46bb-850b-862c50de8a15"},"text":"AisleFootTrafficData\n|where  todatetime(RecordedOn) >= _startTime\n|where storeid == _store\n|summarize aftertraffic = round(sum(after_traffic),0)","id":"3e4f58e9-2103-421f-840e-2f43cedec31b","usedVariables":["_startTime","_store"]},{