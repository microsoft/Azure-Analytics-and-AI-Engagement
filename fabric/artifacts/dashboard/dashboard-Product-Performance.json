uedUtcTime >= _startTime\n|join kind=inner external_table('store') on StoreLocation\n|where StoreID  == _store\n|summarize LastRestockingDate =  max(LastRestockDateTime) by StoreLocation, ProductName","id":"0feb909c-92e7-49a0-aba3-824b7ca6d407","usedVariables":["_startTime","_store"]},{"dataSource":{"kind":"inline","dataSourceId":"e0f6e180-16c0-4e01-b03c-19d9f51f48e1"},"text":"// Please enter your KQL query (Example):\n// <table name>\n// | where <datetime column> between (['_startTime'] .. ['_endTime']) // Time range filtering\n// | take 100\n// Store\n// | distinct StoreID\n// | sort by StoreID asc \n\nexternal_table('store')\n| join kind = inner external_table(\"factsales(snowflake)\") on StoreLocation\n| distinct StoreID","id":"67388e82-fed1-4e20-b079-6e93ac4416ef","usedVariables":[]}]}