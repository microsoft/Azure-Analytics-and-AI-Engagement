    {
      "name": "[concat(parameters('storage_account_name'), '/default/databricks')]",
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2020-08-01-preview",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices',  parameters('storage_account_name'), 'default')]",
        "[resourceId('Microsoft.Storage/storageAccounts',  parameters('storage_account_name'))]"
      ],
      "properties": {
        "defaultEncryptionScope": "$account-encryption-key",
        "denyEncryptionScopeOverride": false,
        "publicAccess": "Container"
      }
    },
        {
      "name": "[concat(parameters('storage_account_name'), '/default/datawarehouse')]",
